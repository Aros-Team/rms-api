  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum(rate(rms_auth_login_total{application=\"rms\"}[5m])) * 60",
          "legendFormat": "Logins/min",
          "refId": "A"
        }
      ],
      "title": "Logins Totales",
      "description": "Tasa total de intentos de login por minuto",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum(rate(rms_auth_login_total{application=\"rms\", status=\"success\"}[5m])) / sum(rate(rms_auth_login_total{application=\"rms\"}[5m])) * 100",
          "legendFormat": "% Éxito",
          "refId": "A"
        }
      ],
      "title": "Ratio Éxito Login",
      "description": "Porcentaje de logins exitosos sobre el total de intentos",
      "type": "gauge",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum by (status) (rate(rms_auth_login_total{application=\"rms\"}[5m])) * 60",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Logins por Status",
      "description": "Tendencia de logins exitosos, fallidos y TFA requerido",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum by (type) (rate(rms_password_reset_total{application=\"rms\"}[5m])) * 60",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "title": "Password Reset",
      "description": "Tendencia de solicitudes y completaciones de reseteo de password",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    }
  ],
