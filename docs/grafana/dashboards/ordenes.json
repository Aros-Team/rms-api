      ],
      "title": "Órdenes Entregadas",
      "description": "Tasa de órdenes entregadas exitosamente por minuto",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "displayName": "Entregadas/min"
          }
        }
      }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum(rate(rms_order_delivered_total[5m])) / sum(rate(rms_order_created_total[5m])) * 100",
          "legendFormat": "% Éxito",
          "refId": "A"
        }
      ],
      "title": "Ratio de Éxito",
      "description": "Porcentaje de órdenes creadas que fueron entregadas exitosamente",
      "type": "gauge",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum by (to) (rate(rms_order_status_transition_total[5m])) * 60",
          "legendFormat": "{{to}}",
          "refId": "A"
