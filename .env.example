# =============================================================================
# CONFIGURACIÓN DEL ENTORNO
# =============================================================================

# Modo de ejecución: dev | prod
# - dev: Admin persistido con DUMMY_EMAIL (no recibe correos reales)
# - prod: Admin persistido con ADMIN_EMAIL (recibe correos reales)
APP_ENV=dev

# =============================================================================
# CONFIGURACIÓN DE BASE DE DATOS - DESARROLLO LOCAL
# =============================================================================

DB_NAME=mydb
DB_PASSWORD=mypassword

# Para prod definir: DB_NAME, DB_PASSWORD y SPRING_DATASOURCE_URL


# =============================================================================
# CREDENCIALES DE ADMINISTRADOR
# =============================================================================

# Email del administrador en PRODUCCIÓN
# REQUERIDO si APP_ENV=prod
ADMIN_EMAIL=?

# Email del administrador en DESARROLLO
# REQUERIDO si APP_ENV=dev
DUMMY_EMAIL=admin@dev.local

# =============================================================================
# CONFIGURACIÓN DE MAIL (DESARROLLO LOCAL)
# * CAMBIAR EN PRODUCCIÓN* =============================================================================

MAIL_URL=http://localhost:8001

# API KEY DE RESEND (PARA ENVIAR EMAILS REALES)
RESEND_API_KEY=?

# DOMINIO PARA EL SERVICIO DE MAIL (solo se pueden enviar correos al email con el que se crea la cuenta de resend)
DOMAIN=resend.dev

# =============================================================================
# CONFIGURACIÓN DE JWT
# =============================================================================
# IMPORTANTE: Se pueden generar con el comando: task jwtkeys

# Clave pública RSA para validar tokens (formato PEM)
JWT_PUBLIC_KEY=

# Clave privada RSA para firmar tokens (formato PEM)
JWT_PRIVATE_KEY=


# =============================================================================
# CONFIGURACIÓN DE CORS
# =============================================================================

# origines permitdos en el CORS
CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*
