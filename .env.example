# =============================================================================
# CONFIGURACIÓN DE BASE DE DATOS
# =============================================================================

DB_HOST=localhost
DB_PORT=3306
DB_NAME=rmsdb
DB_ROOT_PASSWORD=?

# =============================================================================
# CONFIGURACIÓN DEL ENTORNO
# =============================================================================

# Modo de ejecución: development | production
# - development: Admin temporal que se regenera en cada inicio
# - production: Admin persistido en base de datos
APP_ENV=development

# =============================================================================
# CREDENCIALES DE ADMINISTRADOR
# =============================================================================

# Email del administrador en PRODUCCIÓN
# REQUERIDO si APP_ENV=production
ADMIN_EMAIL=

# Email del administrador en DESARROLLO
# REQUERIDO si APP_ENV=development
# Ejemplo: admin@development.local
DUMMY_EMAIL=admin@development.local

# =============================================================================
# CONFIGURACIÓN DE EMAIL
# =============================================================================

MAIL_URL=?

# =============================================================================
# CONFIGURACIÓN DE JWT
# =============================================================================

# Clave pública RSA para validar tokens (formato PEM)
JWT_PUBLIC_KEY=

# Clave privada RSA para firmar tokens (formato PEM)
JWT_PRIVATE_KEY=
