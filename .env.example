# =============================================================================
# CONFIGURACIÓN DE BASE DE DATOS - DESARROLLO LOCAL
# =============================================================================
# IMPORTANTE: Para producción (Cloud Run), usa las variables de Cloud SQL IAM

# Desarrollo local - Conexión TCP/IP directa
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rmsdb
DB_USERNAME=root
DB_PASSWORD=tu_password_local

# Production (Cloud Run): NO usar estas vars, usar CLOUD_SQL_INSTANCE
# DB_HOST, DB_PORT, DB_URL no son necesarios en prod
# CLOUD_SQL_INSTANCE=proyecto:region:instancia

# =============================================================================
# CONFIGURACIÓN DEL ENTORNO
# =============================================================================

# Modo de ejecución: dev | prod
# - dev: Admin persistido con DUMMY_EMAIL (no recibe correos reales)
# - prod: Admin persistido con ADMIN_EMAIL (recibe correos reales)
APP_ENV=dev

# Versión de la aplicación (usada para Docker tags y build)
# Ejemplo: 0.1.0, 0.2.0, 1.0.0
APP_VERSION=0.1.0

# =============================================================================
# CREDENCIALES DE ADMINISTRADOR
# =============================================================================

# Email del administrador en PRODUCCIÓN
# REQUERIDO si APP_ENV=prod
ADMIN_EMAIL=

# Email del administrador en DESARROLLO
# REQUERIDO si APP_ENV=dev
# Ejemplo: admin@dev.local
DUMMY_EMAIL=admin@dev.local

# =============================================================================
# CONFIGURACIÓN DE EMAIL
# =============================================================================

MAIL_URL=?

# =============================================================================
# CONFIGURACIÓN DE JWT
# =============================================================================

# Clave pública RSA para validar tokens (formato PEM)
JWT_PUBLIC_KEY=

# Clave privada RSA para firmar tokens (formato PEM)
JWT_PRIVATE_KEY=

# =============================================================================
# PRODUCCIÓN
# =============================================================================

# Logging en producción (solo WARN y ERROR)
# Descomenta y ajusta si APP_ENV=prod
# LOG_LEVEL_ROOT=ERROR
# LOG_LEVEL_APP=WARN
# LOG_FLYWAY=ERROR
# LOG_REQUEST=ERROR

# Desactivar Swagger en producción
# Descomenta si APP_ENV=prod
# SWAGGER_ENABLED=false
